{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":dependencyDashboard"],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Major-version updates for security-sensitive deps require manual review.",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk",
        "@anthropic-ai/sdk",
        "@e2b/code-interpreter",
        "drizzle-orm",
        "hono",
        "wrangler",
        "@neondatabase/serverless"
      ],
      "matchUpdateTypes": ["major"],
      "addLabels": ["needs-manual-review"],
      "automerge": false
    },
    {
      "description": "Patch updates for tooling: auto-merge after CI passes.",
      "matchPackageNames": ["vitest", "tsup", "typescript", "@biomejs/biome"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  }
}
