---
interface Props {
  title: string;
  description?: string;
  pubDate?: string;
  author?: string;
}
const { title, description, pubDate, author } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Patch</title>
    {description && <meta name="description" content={description} />}
    {description && <meta property="og:description" content={description} />}
    <meta property="og:title" content={title} />
    <meta property="og:type" content="article" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <style>
      body {
        margin: 0;
        background: #000;
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.6;
      }
      .nav {
        max-width: 720px;
        margin: 0 auto;
        padding: 32px 24px 0;
        font-size: 14px;
      }
      .nav a {
        color: #999;
        text-decoration: none;
        margin-right: 16px;
      }
      .nav a:hover {
        color: #fff;
      }
      article {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 24px 80px;
      }
      article h1 {
        font-size: 36px;
        line-height: 1.15;
        margin: 0 0 8px;
      }
      .meta {
        color: #999;
        font-size: 14px;
        margin-bottom: 48px;
      }
      article h2 {
        font-size: 22px;
        margin-top: 48px;
        margin-bottom: 16px;
      }
      article p {
        margin: 0 0 18px;
      }
      article a {
        color: #fff;
        text-underline-offset: 3px;
      }
      article code {
        font-family: "SF Mono", Menlo, monospace;
        font-size: 0.9em;
        background: #161616;
        padding: 1px 5px;
      }
      article pre {
        background: #0a0a0a;
        border: 1px solid #222;
        padding: 16px 20px;
        overflow-x: auto;
        margin: 24px 0;
      }
      article pre code {
        background: transparent;
        padding: 0;
        font-size: 13px;
      }
      article ol,
      article ul {
        padding-left: 22px;
      }
      article li {
        margin-bottom: 4px;
      }
      article blockquote {
        border-left: 2px solid #fff;
        margin: 24px 0;
        padding-left: 16px;
        opacity: 0.85;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <a href="/">← patch</a>
      <a href="/blog">all posts</a>
    </nav>
    <article>
      <h1>{title}</h1>
      <div class="meta">
        {author} · {pubDate}
      </div>
      <slot />
    </article>
  </body>
</html>
